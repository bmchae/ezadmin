# ezadmin 환경 변수 예시.
# 실제 값은 이 파일을 .env로 복사하여 수정하세요.
# .env는 .gitignore에 포함되어 있어 커밋되지 않습니다.
#
# ──────────────────────────────────────────────
# 외부 접근(WAN) HTTP Basic Auth 자격증명
# ──────────────────────────────────────────────
# - LAN/localhost(127.0.0.1, 192.168.x.x, 10.x.x.x, 172.16~31.x.x)에서는
#   인증이 적용되지 않습니다.
# - 외부 접근 시 브라우저가 사용자명/비밀번호를 묻습니다.
# - 비밀번호 해시는 다음 명령으로 생성하세요:
#     python scripts/gen_password_hash.py
# - 해시 값에 '$' 문자가 들어 있으므로 반드시 작은따옴표로 감싸세요.

WEB_AUTH_USER=admin
WEB_AUTH_PASSWORD_HASH='pbkdf2:sha256:600000$REPLACE_WITH_REAL_HASH'

# 역프록시(nginx 등) 뒤에 배포한 경우, 클라이언트 IP를 X-Forwarded-For에서
# 추출하려면 1로 설정하세요. 직접 노출 시에는 0 유지 (기본).
# TRUST_PROXY=0
